Checks: >
  -*,
  bugprone-*,
  -bugprone-easily-swappable-parameters,
  -bugprone-invalid-enum-default-initialization,
  -bugprone-suspicious-stringview-data-usage,
  clang-analyzer-*,
  cppcoreguidelines-narrowing-conversions,
  cppcoreguidelines-avoid-goto,
  cppcoreguidelines-pro-type-member-init,
  modernize-*,
  performance-*,
  portability-*,
  -portability-avoid-pragma-once,
  readability-const-return-type,
  readability-container-size-empty,
  readability-identifier-naming,
  readability-inconsistent-declaration-parameter-name,
  readability-use-anyofallof
WarningsAsErrors: '*'
HeaderFilterRegex: '(^|/)(app|src)/'
# A GCC-generated compile database contains GCC-only warning switches. Clang
# tooling should ignore those switches while retaining the project diagnostics.
ExtraArgs:
  - '-Wno-unknown-warning-option'
CheckOptions:
  - key: readability-identifier-naming.NamespaceCase
    value: lower_case
  - key: readability-identifier-naming.ClassCase
    value: CamelCase
  - key: readability-identifier-naming.StructCase
    value: CamelCase
  - key: readability-identifier-naming.EnumCase
    value: CamelCase
  - key: readability-identifier-naming.FunctionCase
    value: lower_case
  - key: readability-identifier-naming.VariableCase
    value: lower_case
  - key: readability-identifier-naming.ClassMemberCase
    value: lower_case
  - key: readability-identifier-naming.ClassMemberSuffix
    value: '_'
  - key: readability-identifier-naming.ClassConstantCase
    value: lower_case
  - key: readability-identifier-naming.ClassConstantPrefix
    value: 'k_'
  - key: modernize-use-trailing-return-type.TransformFunctions
    value: true
  - key: modernize-use-trailing-return-type.TransformLambdas
    value: none
